# pi 0.75.0 moved user-scoped npm extensions from npm's global root to this
# isolated tree (~/.pi/agent/npm/). In the new layout npm has to resolve the
# `@earendil-works/pi-coding-agent` peer for every extension, and several
# published pi extensions declare non-conforming peer ranges (exact pins,
# carets, etc.) instead of the `"*"` documented in pi's packages.md. Any two
# extensions that disagree on the peer version cause `pi update` to fail with
# ERESOLVE. This flag tells npm to ignore peer-dep conflicts and install
# anyway; the host pi binary is what actually loads extensions at runtime, so
# the peer version recorded in this tree is irrelevant in practice.
legacy-peer-deps=true
